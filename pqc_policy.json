{
  "pqc_policies": [
    {
      "name": "PQC-1 - Enforce Post-Quantum Cryptography Standards",
      "description": "Ensures deployments use quantum-resistant cryptographic algorithms and avoid deprecated crypto that is vulnerable to quantum attacks",
      "rationale": "Traditional cryptographic algorithms (RSA, ECC, DSA) will be vulnerable to quantum computers. Organizations must transition to post-quantum cryptography to maintain security.",
      "remediation": "Update applications to use NIST-approved post-quantum cryptographic algorithms: CRYSTALS-Dilithium, CRYSTALS-KYBER, FALCON, or SPHINCS+. Avoid RSA keys < 3072 bits, ECC keys < 256 bits, and deprecated hash functions.",
      "disabled": false,
      "categories": [
        "Cryptography",
        "Security Best Practices",
        "Vulnerability Management"
      ],
      "lifecycleStages": [
        "DEPLOY"
      ],
      "eventSource": "NOT_APPLICABLE",
      "exclusions": [],
      "scope": [],
      "severity": "HIGH_SEVERITY",
