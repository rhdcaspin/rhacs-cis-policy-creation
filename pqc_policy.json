          "sectionName": "Container Configuration",
          "policyGroups": [
            {
              "fieldName": "Environment Value",
              "booleanOperator": "OR",
              "negate": false,
              "values": [
                {
                  "value": ".*RSA.*1024.*"
                },
                {
                  "value": ".*RSA.*2048.*"
                },
                {
                  "value": ".*RSA_KEYSIZE=(1024|2048).*"
                },
                {
                  "value": ".*SSL_RSA_KEYSIZE=(1024|2048).*"
                }
              ]
            }
          ]
        },
