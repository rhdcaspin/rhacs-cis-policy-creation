    {
      "name": "PQC-3 - Detect Deprecated Hash Algorithms",
      "description": "Detects use of cryptographically weak hash algorithms (MD5, SHA-1) that are vulnerable to quantum attacks",
      "rationale": "MD5 and SHA-1 are cryptographically broken and will be even more vulnerable with quantum computing. Applications should use SHA-256, SHA-3, or post-quantum hash functions.",
      "remediation": "Update applications to use SHA-256, SHA-3, or NIST-approved post-quantum hash functions. Remove all MD5 and SHA-1 usage.",
      "disabled": false,
      "categories": [
        "Cryptography",
        "Security Best Practices"
