    {
      "name": "PQC-2 - Detect Weak RSA Key Configurations",
      "description": "Detects RSA keys smaller than 3072 bits which are vulnerable to quantum attacks and should be upgraded to post-quantum algorithms",
      "rationale": "RSA keys smaller than 3072 bits can be broken by quantum computers using Shor's algorithm. NIST recommends transitioning to post-quantum cryptography.",
      "remediation": "Replace RSA keys with NIST-approved post-quantum algorithms: CRYSTALS-Dilithium for signatures, CRYSTALS-KYBER for key exchange.",
      "disabled": false,
      "categories": [
        "Cryptography",
        "Security Best Practices"
      ],
      "lifecycleStages": [
        "DEPLOY"
      ],
      "eventSource": "NOT_APPLICABLE",
      "exclusions": [],
      "scope": [],
      "severity": "MEDIUM_SEVERITY",
