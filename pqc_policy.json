    {
      "name": "PQC-4 - Require PQC-Ready Libraries",
      "description": "Ensures containers include post-quantum cryptography ready libraries and frameworks",
      "rationale": "Applications must include PQC-ready cryptographic libraries to support quantum-resistant algorithms like CRYSTALS-Dilithium, CRYSTALS-KYBER, FALCON, and SPHINCS+.",
      "remediation": "Include PQC-ready libraries such as OpenSSL 3.0+, Bouncy Castle with PQC support, or dedicated PQC libraries like liboqs.",
      "disabled": false,
      "categories": [
        "Cryptography",
        "Security Best Practices"
