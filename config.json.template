{
  "rhacs": {
    "central_url": "https://your-rhacs-central.example.com:443",
    "api_token": "your-rhacs-api-token-here"
  },
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(levelname)s - %(message)s"
