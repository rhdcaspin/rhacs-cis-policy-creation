{
  "data_sovereignty_policies": [
    {
      "name": "Data-Sovereignty-1 - Restrict Container Registry to Approved Regions (EU)",
      "description": "Ensure container images are pulled only from EU-based registries to maintain data sovereignty",
      "disabled": false,
      "categories": [
        "Data Sovereignty",
        "Supply Chain Security"
      ],
      "lifecycleStages": [
        "DEPLOY",
        "BUILD"
      ],
      "eventSource": "NOT_APPLICABLE",
      "exclusions": [],
      "scope": [],
      "severity": "HIGH_SEVERITY",
      "enforcementActions": [
        "FAIL_DEPLOYMENT",
        "FAIL_BUILD_ENFORCEMENT"
      ],
      "notifiers": [],
      "policyVersion": "1.1",
      "policySections": [
        {
          "sectionName": "Image Configuration",
          "policyGroups": [
            {
              "fieldName": "Image Registry",
              "booleanOperator": "OR",
              "negate": true,
              "values": [
                {
                  "value": "eu.gcr.io"
                },
                {
                  "value": ".*\\.eu\\..*"
                },
                {
                  "value": ".*-eu\\..*"
                },
                {
                  "value": "registry.eu-.*"
                },
                {
                  "value": ".*\\.dkr\\.ecr\\.eu-.*\\.amazonaws\\.com"
                }
              ]
            }
          ]
        }
      ],
      "mitreAttackVectors": [
        {
          "tactic": "TA0010",
          "techniques": [
            "T1537"
          ]
        }
      ],
      "criteriaLocked": false,
      "mitreVectorsLocked": false,
      "isDefault": false
    },
