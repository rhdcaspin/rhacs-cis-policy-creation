# RHACS NIST 800-190 Compliance Reporting Configuration
# Copy this file to .env and fill in your values

# RHACS Instance URL (required)
RHACS_URL=https://your-rhacs-instance.com

# RHACS API Token (required)
# Generate this from RHACS: Platform Configuration > Integrations > API Token
RHACS_API_TOKEN=your-api-token-here

# SSL Verification (optional, default: false)
# Set to 'true' for production environments with valid SSL certificates
# Set to 'false' for demo/dev environments
RHACS_VERIFY_SSL=false
